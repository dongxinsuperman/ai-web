# 端口
AIWEB_PORT=8009

# 数据库（PostgreSQL，需提前创建库 aiweb）
AIWEB_DATABASE_URL=postgresql+asyncpg://postgres:postgres@127.0.0.1:5432/aiweb

# 主模型 VLM（决策循环）—— 只配 provider + base_url，端点按家自动推导（AI phone 风格）
# provider：doubao | claude | openai
# base_url 填 API 根（含版本段），不要带 /responses /messages 后缀，系统会自动拼：
#   doubao → BASE/responses           （如 https://ark.cn-beijing.volces.com/api/v3）
#   claude → BASE/messages            （如 https://api.anthropic.com/v1）
#   openai → BASE/responses           （如 https://api.openai.com/v1）
AIWEB_VLM_PROVIDER=doubao
AIWEB_VLM_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
AIWEB_VLM_API_KEY=__FILL_ME__
AIWEB_VLM_MODEL=__ENDPOINT_OR_MODEL__
# 各家细项（仅对应 provider 生效）
# AIWEB_VLM_HISTORY_WINDOW_STEPS=12        # claude 客户端历史滑窗（步对）
# AIWEB_VLM_MAIN_THINKING_BUDGET=0         # claude thinking 预算 tokens，0=关
# AIWEB_VLM_MAIN_PROMPT_CACHING_ENABLED=false  # claude prompt caching
# AIWEB_VLM_MAIN_REASONING_EFFORT=medium   # openai：low|medium|high

# 辅助模型（二次断言 / 免登编译）—— 与主模型对等的独立一套，可指向不同家/模型。
# 端点推导：doubao → BASE/responses；claude → BASE/messages；openai → BASE/chat/completions
# base_url / api_key / model 任一留空 = 回退主模型对应项（同家时可少填）。
AIWEB_ASSISTANT_PROVIDER=doubao
AIWEB_ASSISTANT_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
AIWEB_ASSISTANT_API_KEY=__FILL_ME__
AIWEB_ASSISTANT_MODEL=__ENDPOINT_OR_MODEL__

# 浏览器 Agent 节点容量。Server 只分发，浏览器由同名 Agent 执行。
# 本机测试也要启动 Agent，例如：
#   python -m aiweb.agent --server http://127.0.0.1:8009 --agent-id mac-01
AIWEB_BROWSER_SLOTS={"mac-01":{"chrome":1,"firefox":0,"webkit":0}}

# 有头/无头：本地有显示器设 false 跑有头，被风控概率更低；服务器/Pod 用 true。
AIWEB_HEADLESS=true

# 鉴权：留空=匿名（本地/内网）。公司部署可填 token，则所有 /api 需带 Authorization: Bearer <token>。
AIWEB_API_TOKEN=
